{
  "name": "@munesoft/asyncx",
  "version": "1.204.12",
  "description": "Unified async control for JavaScript: retries, timeouts, caching, concurrency, cancellation, and circuit breakers — one function.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "async", "retry", "timeout", "cache", "concurrency", "abort",
    "circuit-breaker", "deduplication", "promise", "typescript",
    "async-retry", "promise-timeout", "rate-limit", "async-cache",
    "javascript-async", "node-retry", "async-control", "promise-queue"
  ],
  "author": "munesoft",
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/munesoft/asyncx.git"
  },
  "homepage": "https://github.com/munesoft/asyncx#readme",
  "bugs": {
    "url": "https://github.com/munesoft/asyncx/issues"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}