{
  "name": "@munesoft/envx",
  "version": "1.0.1",
  "description": "One-line .env loader, validator, and type-safe config for Node.js",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config.js"
  },
  "types": "./types/index.d.ts",
  "bin": {
    "envx": "bin/envx.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "eslint src/"
  },
  "keywords": [
    "env",
    "dotenv",
    "config",
    "validation",
    "typescript",
    "environment"
  ],
  "author": "Munesoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/munesoft/envx.git"
  },
  "homepage": "https://github.com/munesoft/envx#readme",
  "bugs": {
    "url": "https://github.com/munesoft/envx/issues"
  },
  "dependencies": {},
  "devDependencies": {
    "jest": "^29.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}