{
  "name": "@munesoft/idx",
  "version": "1.0.10",
  "description": "High-performance, flexible ID generation library",
  "author": "munesoft",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/munesoft/idx.git"
  },
  "bugs": {
    "url": "https://github.com/munesoft/idx/issues"
  },
  "homepage": "https://github.com/munesoft/idx#readme",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "bench": "node benchmarks/bench.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "keywords": ["id", "uuid", "nanoid", "ulid", "generator", "random", "unique"]
}