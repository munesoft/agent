{
  "name": "@munesoft/retryx",
  "version": "1.114.12",
  "description": "Smart retry & backoff engine for APIs and AI workflows. Zero-dependency, AI-aware rate limit handling, exponential backoff with jitter.",
  "keywords": [
    "retry",
    "backoff",
    "exponential-backoff",
    "rate-limit",
    "rate-limiting",
    "retry-after",
    "jitter",
    "promise",
    "async",
    "ai",
    "openai",
    "anthropic",
    "fetch",
    "http",
    "resilience",
    "fault-tolerance",
    "typescript",
    "zero-dependencies",
    "esm",
    "browser",
    "nodejs"
  ],
  "license": "MIT",
  "author": "munesoft",
  "homepage": "https://github.com/munesoft/retryx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/munesoft/retryx.git"
  },
  "bugs": {
    "url": "https://github.com/munesoft/retryx/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=14"
  },
  "scripts": {
    "build": "tsup",
    "test": "node --test --import tsx test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
