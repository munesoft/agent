{
  "name": "@munesoft/loopx",
  "version": "1.0.1",
  "description": "Universal loop controller for AI agents and async workflows. Control iterative execution, prevent infinite loops, and manage agent cycles with precision.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && node scripts/build-cjs.mjs",
    "test": "node --test test/*.test.js test/*.test.cjs",
    "test:watch": "node --test --watch test/*.test.js",
    "prepublishOnly": "npm run build && npm test",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "loop",
    "loop-controller",
    "ai-agent",
    "agent-loop",
    "async-loop",
    "iteration",
    "workflow",
    "infinite-loop-prevention",
    "abortcontroller",
    "async",
    "iterator",
    "control-flow",
    "ai",
    "llm",
    "agent",
    "polling",
    "retry"
  ],
  "author": "munesoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/munesoft/loopx.git"
  },
  "bugs": {
    "url": "https://github.com/munesoft/loopx/issues"
  },
  "homepage": "https://github.com/munesoft/loopx#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "sideEffects": false,
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
