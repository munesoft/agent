{
  "name": "@munesoft/objx",
  "version": "1.0.10",
  "description": "A modern, fast, and safe lodash.get / lodash.set / deep merge alternative for JavaScript and TypeScript",
  "keywords": [
    "lodash",
    "lodash-alternative",
    "lodash-get",
    "lodash-set",
    "lodash-merge",
    "deep-get",
    "deep-set",
    "deep-merge",
    "object-utils",
    "object-path",
    "immutable",
    "immutable-update",
    "typescript",
    "javascript",
    "node",
    "nested-objects",
    "safe-access",
    "prototype-pollution-safe"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./get": {
      "import": "./dist/esm/get/index.js",
      "require": "./dist/cjs/get/index.js",
      "types": "./dist/types/get/index.d.ts"
    },
    "./set": {
      "import": "./dist/esm/set/index.js",
      "require": "./dist/cjs/set/index.js",
      "types": "./dist/types/set/index.d.ts"
    },
    "./merge": {
      "import": "./dist/esm/merge/index.js",
      "require": "./dist/cjs/merge/index.js",
      "types": "./dist/types/merge/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.esm.json && tsc -p tsconfig.cjs.json && tsc -p tsconfig.types.json",
    "test": "npx --yes cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "npx --yes cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/munesoft/objx.git"
  },
  "homepage": "https://github.com/munesoft/objx#readme",
  "bugs": {
    "url": "https://github.com/munesoft/objx/issues"
  },
  "license": "MIT",
  "author": "munesoft"
}
